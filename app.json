{
  "expo": {
    "name": "StarterApp",
    "slug": "starter-app",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "icon": "./assets/app-icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/<project-id>"
    },
    "scheme": "starterapp",
    "ios": {
      "bundleIdentifier": "com.anonymous.starter-app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false,
          "NSAllowsLocalNetworking": true,
          "NSAllowsArbitraryLoadsInMedia": true,
          "NSExceptionDomains": {
            "images.deso.org": {
              "NSIncludesSubdomains": true,
              "NSTemporaryExceptionAllowsInsecureHTTPLoads": true,
              "NSTemporaryExceptionMinimumTLSVersion": "TLSv1.0",
              "NSTemporaryExceptionRequiresForwardSecrecy": false
            },
            "node.deso.org": {
              "NSIncludesSubdomains": true,
              "NSTemporaryExceptionAllowsInsecureHTTPLoads": true,
              "NSTemporaryExceptionMinimumTLSVersion": "TLSv1.0",
              "NSTemporaryExceptionRequiresForwardSecrecy": false
            },
            "videodelivery.net": {
              "NSIncludesSubdomains": true,
              "NSTemporaryExceptionAllowsInsecureHTTPLoads": true,
              "NSTemporaryExceptionMinimumTLSVersion": "TLSv1.0",
              "NSTemporaryExceptionRequiresForwardSecrecy": false
            },
            "lvpr.tv": {
              "NSIncludesSubdomains": true,
              "NSTemporaryExceptionAllowsInsecureHTTPLoads": true,
              "NSTemporaryExceptionMinimumTLSVersion": "TLSv1.0",
              "NSTemporaryExceptionRequiresForwardSecrecy": false
            },
            "mypinata.cloud": {
              "NSIncludesSubdomains": true,
              "NSTemporaryExceptionAllowsInsecureHTTPLoads": true,
              "NSTemporaryExceptionMinimumTLSVersion": "TLSv1.0",
              "NSTemporaryExceptionRequiresForwardSecrecy": false
            }
          }
        }
      }
    },
    "android": {
      "package": "com.anonymous.starterapp"
    },
    "plugins": [
      "expo-web-browser",
      "expo-video",
      "expo-font"
    ],
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/app-icon.png",
      "name": "Starter App",
      "shortName": "StarterApp",
      "description": "Decentralized messaging powered by DeSo",
      "lang": "en",
      "backgroundColor": "#000000",
      "themeColor": "#000000",
      "display": "standalone",
      "orientation": "portrait",
      "startUrl": "/",
      "scope": "/"
    },
    "extra": {
      "eas": {
        "projectId": "5eeffb46-766f-4f4f-b976-01c3f64e23ce"
      }
    }
  }
}
